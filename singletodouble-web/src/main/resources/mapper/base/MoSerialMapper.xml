<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.singletodouble.web.mapper.base.MoSerialMapper">
    
    <resultMap type="MoSerial" id="MoSerialResult">
        <id property="id"    				column="id"    />
        <result property="custBm"    		column="cust_bm"    />
        <result property="serialNumber"    	column="serial_number"    />
        <result property="createBy"    		column="create_by"    />
        <result property="createTime"    	column="create_time"    />
        <result property="updateBy"    		column="update_by"    />
        <result property="updateTime"    	column="update_time"    />
    </resultMap>

    <sql id="selectMoSerialVo">
        select id, cust_bm, serial_number, create_by, create_time, update_by, update_time from mo_serial
    </sql>

    <select id="searchList" parameterType="MoSerial" resultMap="MoSerialResult">
        <include refid="selectMoSerialVo"/>
        <where>  
            <if test="custBm != null  and custBm != ''"> and cust_bm = #{custBm}</if>
            <if test="serialNumber != null "> and serial_number = #{serialNumber}</if>
        </where>
    </select>
    
    <select id="searchDataById" parameterType="Long" resultMap="MoSerialResult">
        <include refid="selectMoSerialVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertData" parameterType="MoSerial" useGeneratedKeys="true" keyProperty="id">
        insert into mo_serial(cust_bm,serial_number,create_by,create_time)
        values(#{custBm}, #{serialNumber}, #{createBy}, NOW())
    </insert>

    <update id="updateData" parameterType="MoSerial">
        update mo_serial
        <trim prefix="SET" suffixOverrides=",">
            <if test="custBm != null">cust_bm = #{custBm},</if>
            <if test="serialNumber != null">serial_number = #{serialNumber},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateBy != null">update_time = NOW(),</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteDataById" parameterType="Long">
        delete from mo_serial where id = #{id}
    </delete>

</mapper>